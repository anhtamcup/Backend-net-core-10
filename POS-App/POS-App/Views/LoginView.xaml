<UserControl x:Class="POS_App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <Border Width="320"
                Padding="30"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="ĐĂNG NHẬP"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- OTP BOX -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,25">

                    <TextBox x:Name="txt1"
                             Width="50"
                             Height="50"
                             Margin="4"
                             FontSize="24"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             MaxLength="1"
                             TextChanged="txt1_TextChanged"/>

                    <TextBox x:Name="txt2"
                             Width="50"
                             Height="50"
                             Margin="4"
                             FontSize="24"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             MaxLength="1"
                             TextChanged="txt2_TextChanged"/>

                    <TextBox x:Name="txt3"
                             Width="50"
                             Height="50"
                             Margin="4"
                             FontSize="24"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             MaxLength="1"
                             TextChanged="txt3_TextChanged"/>

                    <TextBox x:Name="txt4"
                             Width="50"
                             Height="50"
                             Margin="4"
                             FontSize="24"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             MaxLength="1"
                             TextChanged="txt4_TextChanged"/>

                </StackPanel>

                <!-- Button -->
                <Button Content="LOGIN"
                        Height="45"
                        Background="#00824A"
                        Foreground="White"
                        BorderBrush="#00824A"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        Click="Button_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd"
                                            Property="Background"
                                            Value="#009A58"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd"
                                            Property="Background"
                                            Value="#006B3D"/>
                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <!-- Error -->
                <TextBlock x:Name="txtError"
                           Foreground="Red"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Visibility="Collapsed"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>