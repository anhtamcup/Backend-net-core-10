<UserControl x:Class="POS_App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Nút keypad -->
        <Style x:Key="KeypadButtonNumberStyle"
               TargetType="Button"
               BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
            <Setter Property="Background" Value="#F4F4F4"/>
        </Style>

        <Style x:Key="KeypadButtonEnterStyle"
               TargetType="Button"
               BasedOn="{StaticResource KeypadButtonNumberStyle}">
            <Setter Property="Height" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#15B84E"/>
        </Style>

        <!-- Button dưới -->
        <Style x:Key="ActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Height" Value="80"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeM}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Opacity"
                                        Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>


    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- LOGIN -->
        <Grid Grid.Row="0">

            <Border Background="White"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    CornerRadius="15"
                    Padding="15"
                    Width="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="S3POS"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="#1E73E8"
                               HorizontalAlignment="Center"/>

                    <Grid Margin="0,15,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock FontSize="{StaticResource FontSizeL}">
                            <Run Text="Mã nhân viên: "/>
                            <Run Text="000012"
                                 FontWeight="Bold"/>
                        </TextBlock>

                        <TextBlock Grid.Column="1"
                                   Text="Thay đổi"
                                   Foreground="#1E73E8"/>
                    </Grid>


                    <TextBlock Text="Mật khẩu"
                        FontSize="{StaticResource FontSizeL}"
                        Margin="0,5"/>

                    <Border Height="45"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,5,0,10">

                        <ItemsControl x:Name="PasswordDots"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                        FontSize="{StaticResource FontSizeXL}"
                                        Margin="2"
                                        Foreground="#1A1A1A"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- keypad -->
                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <!-- hàng 1 -->
                        <Button Grid.Row="0" Grid.Column="0"
                                Content="7"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="0" Grid.Column="1"
                                Content="8"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="0" Grid.Column="2"
                                Content="9"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Backspace"
                                Click="Backspace_Click"
                                Background="#2563EB"
                                Foreground="White"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>


                        <!-- hàng 2 -->
                        <Button Grid.Row="1" Grid.Column="0"
                                Content="4"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="1" Grid.Column="1"
                                Content="5"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="1" Grid.Column="2"
                                Content="6"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Content="Clear"
                                Click="Clear_Click"
                                Background="#F54545"
                                Foreground="White"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>


                        <!-- hàng 3 -->
                        <Button Grid.Row="2" Grid.Column="0"
                                Content="1"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="2" Grid.Column="1"
                                Content="2"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="2" Grid.Column="2"
                                Content="3"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                        <Button Grid.Row="2"
                                Grid.Column="3"
                                Grid.ColumnSpan="2"
                                Grid.RowSpan="2"
                                Content="Enter"
                                Click="Enter_Click"
                                Style="{StaticResource KeypadButtonEnterStyle}"/>

                        <!-- hàng cuối -->
                        <Button Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Content="0"
                                Click="Number_Click"
                                Style="{StaticResource KeypadButtonNumberStyle}"/>

                    </Grid>

                </StackPanel>

            </Border>

        </Grid>


        <!-- BUTTON HÀNG 1 -->
        <UniformGrid Grid.Row="1"
                     Columns="4">

            <Button Content="Bán hàng"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#18D56D"/>

            <Button Content="Bảng kê quyết toán"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#6172F3"/>

            <Button Content="Mở ca / Kết ca"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#2D31A6"/>

            <Button Content="Nộp / Rút tiền"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#E0A000"/>

        </UniformGrid>


        <!-- BUTTON HÀNG 2 -->
        <UniformGrid Grid.Row="2" Columns="5">
            <Button Content="Quản lý" Style="{StaticResource ActionButtonStyle}" Background="#0B4A6F"/>
            <Button Content="Mở ca / Kết ca" Style="{StaticResource ActionButtonStyle}" Background="#2D31A6"/>
            <Button Content="Đồng bộ" Style="{StaticResource ActionButtonStyle}" Background="#065986"/>
            <Button Content="Đối soát" Style="{StaticResource ActionButtonStyle}" Background="#2D3282"/>
            <Button Content="Thoát" Style="{StaticResource ActionButtonStyle}" Background="#065986"/>
        </UniformGrid>

    </Grid>

</UserControl>