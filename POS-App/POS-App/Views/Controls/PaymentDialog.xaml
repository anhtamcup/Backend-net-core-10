<Window x:Class="POS_App.Views.Controls.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POS_App.Views.Controls"
        mc:Ignorable="d"
        Title="PaymentDialog" Height="450" Width="800">

    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundColorHeader" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0C2340" Offset="0"/>
            <GradientStop Color="#163659" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeL}"/>
        </Style>

        <Style x:Key="ButtonActionStyle" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeM}" />
        </Style>

        <Style x:Key="ButtonNumberStyle" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeM}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Margin" Value="2" />
        </Style>
        
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Name="grHeader" Background="{StaticResource BackgroundColorHeader}">
            <TextBlock Style="{StaticResource HeaderLabel}" Text="Thanh toán hóa đơn"  />
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBlock  Text="Số tiền cần thu"  />
            </Grid>
            <Grid Grid.Column="1" Background="Red">

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="0" Grid.Column="0" Content="10k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="0" Grid.Column="1" Content="20k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="0" Grid.Column="2" Content="50k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="0" Grid.Column="3" Content="100k" />

                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="1" Grid.Column="0" Content="200k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="1" Grid.Column="1" Content="500k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="1" Grid.Column="2" Content="1000k" />
                <Button Style="{StaticResource ButtonNumberStyle}" Grid.Row="1" Grid.Column="3" Content="2000k" />

                <Grid Grid.Row="2" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="0" Content="7" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="1" Content="8" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="2" Content="9" />
                </Grid>

                <Grid Grid.Row="3" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="0" Content="4" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="1" Content="5" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="2" Content="6" />
                </Grid>

                <Grid Grid.Row="4" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="0" Content="1" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="1" Content="2" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="2" Content="3" />
                </Grid>

                <Grid Grid.Row="5" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="0" Content="0" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="1" Content="00" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="2" Content="" />
                </Grid>

                <Grid Grid.Row="6" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="0" Content="CLEAR" />
                    <Button Style="{StaticResource ButtonNumberStyle}" Grid.Column="1" Content="X" />
                </Grid>

            </Grid>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Content="Hủy (ESC)"
                    Background="#80B8C4E0 "
                    Style="{StaticResource ButtonActionStyle}"
                    Foreground="#2E384E"
                    Margin="0,0,10,0"
                    />
            <Button Content="Xác nhận thanh toán (F12)"
                    Background="{StaticResource bg-button-green}"
                    Style="{StaticResource ButtonActionStyle}"
                    Foreground="#FFFFFF"
                    
                    />
        </WrapPanel>
    </Grid>
</Window>
