<Window x:Class="POS_App.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:POS_App.ViewModels"
        Title="CustomerWindow"
        Height="450"
        Width="800">

    <Grid>

        <StackPanel x:Name="OrderPanel"
                    Visibility="Collapsed">

            <DataGrid x:Name="CartGrid"
                      ItemsSource="{Binding CurrentView.CartItems}"
                      AutoGenerateColumns="True"/>

        </StackPanel>

    </Grid>

</Window>