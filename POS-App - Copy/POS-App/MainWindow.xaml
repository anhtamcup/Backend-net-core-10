<!--<Window x:Class="POS_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POS_App"
        mc:Ignorable="d"
        Title="MartPOS — Hệ thống bán hàng siêu thị"
        Height="768" Width="1366"
        MinHeight="768" MinWidth="1366"
        Background="#EEF1F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        --><!-- ===== COLOR PALETTE ===== --><!--
        <SolidColorBrush x:Key="BgBrush"           Color="#EEF1F5"/>
        <SolidColorBrush x:Key="SurfaceBrush"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Surface2Brush"     Color="#F7F9FC"/>
        <SolidColorBrush x:Key="Surface3Brush"     Color="#EEF2F7"/>
        <SolidColorBrush x:Key="BorderBrush"       Color="#D8DEE7"/>
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#B8C1CF"/>

        <SolidColorBrush x:Key="InkBrush"          Color="#0B1C33"/>
        <SolidColorBrush x:Key="Ink2Brush"         Color="#2C3E5A"/>
        <SolidColorBrush x:Key="Ink3Brush"         Color="#5A6B82"/>
        <SolidColorBrush x:Key="InkMuteBrush"      Color="#8696AD"/>

        <SolidColorBrush x:Key="PrimaryBrush"      Color="#0A3D62"/>
        <SolidColorBrush x:Key="Primary2Brush"     Color="#134D75"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#E7F0F8"/>

        <SolidColorBrush x:Key="AccentBrush"       Color="#00824A"/>
        <SolidColorBrush x:Key="Accent2Brush"      Color="#00A35D"/>
        <SolidColorBrush x:Key="AccentLightBrush"  Color="#E6F5ED"/>

        <SolidColorBrush x:Key="WarmBrush"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="Warm2Brush"        Color="#D97706"/>
        <SolidColorBrush x:Key="WarmLightBrush"    Color="#FEF3C7"/>

        <SolidColorBrush x:Key="DangerBrush"       Color="#C0392B"/>
        <SolidColorBrush x:Key="Danger2Brush"      Color="#962D20"/>
        <SolidColorBrush x:Key="DangerLightBrush"  Color="#FDEBE9"/>

        <SolidColorBrush x:Key="InfoBrush"         Color="#1E88C4"/>
        <SolidColorBrush x:Key="InfoLightBrush"    Color="#E3F2FB"/>

        <SolidColorBrush x:Key="GreenLightBrush"   Color="#E8F7EF"/>
        <SolidColorBrush x:Key="AmberLightBrush"   Color="#FEF3C7"/>
        <SolidColorBrush x:Key="KeypadBgBrush"     Color="#D9EBF7"/>
        <SolidColorBrush x:Key="WhiteBrush"        Color="#FFFFFF"/>

        --><!-- ===== HEADER GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0A3D62" Offset="0"/>
            <GradientStop Color="#134D75" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== ACCENT GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00A35D" Offset="0"/>
            <GradientStop Color="#00824A" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== CART HEAD GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="CartHeadGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#EEF2F7" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== TOTALS GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="TotalsGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F7F9FC" Offset="0"/>
            <GradientStop Color="#E9EEF5" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== STATUS BAR GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="StatusBarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F1F4F9" Offset="0"/>
            <GradientStop Color="#E6EBF1" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== AVATAR GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="AvatarGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F59E0B" Offset="0"/>
            <GradientStop Color="#D97706" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== LOGO GRADIENT ===== --><!--
        <LinearGradientBrush x:Key="LogoGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00824A" Offset="0"/>
            <GradientStop Color="#00A35D" Offset="1"/>
        </LinearGradientBrush>

        --><!-- ===== HEADER ICON BUTTON STYLE ===== --><!--
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- ===== TOOL BUTTON STYLE ===== --><!--
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#B8C1CF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#2C3E5A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F7F9FC"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8696AD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- ===== ACTION BUTTON BASE STYLE ===== --><!--
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8696AD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- ===== KEYPAD KEY STYLE ===== --><!--
        <Style x:Key="KeypadKeyStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8DEE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0B1C33"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B9D9ED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A0C8DF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- ===== KEYPAD SPECIAL KEY STYLE ===== --><!--
        <Style x:Key="KeypadSpecialStyle" TargetType="Button" BasedOn="{StaticResource KeypadKeyStyle}">
            <Setter Property="Background" Value="#B3D8EE"/>
            <Setter Property="Foreground" Value="#0B1C33"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        --><!-- ===== KEYPAD ENTER STYLE ===== --><!--
        <Style x:Key="KeypadEnterStyle" TargetType="Button" BasedOn="{StaticResource KeypadKeyStyle}">
            <Setter Property="Background" Value="#00824A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        --><!-- ===== KEYPAD CANCEL STYLE ===== --><!--
        <Style x:Key="KeypadCancelStyle" TargetType="Button" BasedOn="{StaticResource KeypadKeyStyle}">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        --><!-- ===== TAB BUTTON STYLE ===== --><!--
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#5A6B82"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0B1C33"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        --><!-- ===== SCAN INPUT STYLE ===== --><!--
        <Style x:Key="ScanTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#0B1C33"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        --><!-- ===== SCROLL VIEWER STYLE (thin scrollbar) ===== --><!--
        <Style x:Key="CartScrollStyle" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

    </Window.Resources>

    --><!-- ================================================================
         ROOT GRID  — rows: Header | Toolbar | Main | StatusBar
         ================================================================ --><!--
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            --><!-- Header --><!--
            <RowDefinition Height="60"/>
            --><!-- Toolbar --><!--
            <RowDefinition Height="*"/>
            --><!-- Main --><!--
            <RowDefinition Height="30"/>
            --><!-- Status Bar --><!--
        </Grid.RowDefinitions>

        --><!-- ============================================================
             ROW 0  —  HEADER
             ============================================================ --><!--
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}"
                BorderBrush="#062A44" BorderThickness="0,0,0,2">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                --><!-- BRAND --><!--
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    --><!-- Logo box --><!--
                    <Border Width="38" Height="38" CornerRadius="8"
                            Background="{StaticResource LogoGradient}" Margin="0,0,12,0">
                        <TextBlock Text="M" Foreground="White" FontWeight="ExtraBold"
                                   FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    --><!-- Brand text --><!--
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MartPOS" Foreground="White" FontWeight="Bold" FontSize="17"/>
                        <TextBlock Text="Bán hàng • Cashier" Foreground="#A5C0D5" FontSize="10"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    --><!-- Separator --><!--
                    <Border Width="1" Background="#26FFFFFF" Margin="20,8,0,8"/>
                </StackPanel>

                --><!-- SESSION INFO --><!--
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,0,0">
                    --><!-- Số POS --><!--
                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="SỐ POS" Foreground="#99FFFFFF" FontSize="10"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="0016" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" FontFamily="Consolas"/>
                    </StackPanel>
                    --><!-- Mã số --><!--
                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="MÃ SỐ" Foreground="#99FFFFFF" FontSize="10"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="0198" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" FontFamily="Consolas"/>
                    </StackPanel>
                    --><!-- Số lần --><!--
                    <StackPanel Margin="0,0,28,0">
                        <TextBlock Text="SỐ LẦN" Foreground="#99FFFFFF" FontSize="10"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="198 / 220" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" FontFamily="Consolas"/>
                    </StackPanel>
                    --><!-- Date Time --><!--
                    <StackPanel>
                        <TextBlock Text="NGÀY THÁNG" Foreground="#99FFFFFF" FontSize="10"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="txtDateTime" Text="10-05-2026 14:32:18"
                                   Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>

                --><!-- HEADER ACTIONS --><!--
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    --><!-- Settings button --><!--
                    <Button Style="{StaticResource HeaderIconButtonStyle}" ToolTip="Cài đặt">
                        <TextBlock Text="⚙" FontSize="16" Foreground="White"/>
                    </Button>
                    --><!-- Connection button with badge --><!--
                    <Grid Margin="4,0,0,0">
                        <Button Style="{StaticResource HeaderIconButtonStyle}" ToolTip="Kết nối">
                            <TextBlock Text="☰" FontSize="16" Foreground="White"/>
                        </Button>
                        <Border Background="#F59E0B" CornerRadius="8" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Margin="0,2,2,0" Padding="4,1">
                            <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="#0B1C33"/>
                        </Border>
                    </Grid>
                    --><!-- Report button --><!--
                    <Button Style="{StaticResource HeaderIconButtonStyle}" Margin="4,0,0,0" ToolTip="Báo cáo">
                        <TextBlock Text="📈" FontSize="15"/>
                    </Button>
                    --><!-- Message button with badge --><!--
                    <Grid Margin="4,0,0,0">
                        <Button Style="{StaticResource HeaderIconButtonStyle}" ToolTip="Tin nhắn">
                            <TextBlock Text="💬" FontSize="15"/>
                        </Button>
                        <Border Background="#F59E0B" CornerRadius="8" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Margin="0,2,2,0" Padding="4,1">
                            <TextBlock Text="2" FontSize="9" FontWeight="Bold" Foreground="#0B1C33"/>
                        </Border>
                    </Grid>
                    --><!-- User Chip --><!--
                    <Border Background="#1AFFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1"
                            CornerRadius="999" Padding="4,4,10,4" Margin="8,0,0,0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            --><!-- Avatar --><!--
                            <Border Width="30" Height="30" CornerRadius="15"
                                    Background="{StaticResource AvatarGradient}">
                                <TextBlock Text="CT" FontSize="12" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            --><!-- Name + Role --><!--
                            <StackPanel VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="Cao Thảo" FontSize="12" FontWeight="SemiBold"
                                           Foreground="White" LineHeight="14"/>
                                <TextBlock Text="Thu ngân ca chiều" FontSize="10"
                                           Foreground="#B3FFFFFF"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        --><!-- ============================================================
             ROW 1  —  TOOLBAR
             ============================================================ --><!--
        <Border Grid.Row="1" Background="#F7F9FC"
                BorderBrush="#D8DEE7" BorderThickness="0,0,0,1">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                --><!-- Scan / Barcode Input --><!--
                <Border Grid.Column="0" Background="White" BorderBrush="#B8C1CF"
                        BorderThickness="1.5" CornerRadius="6" Margin="0,0,12,0">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="▌▌▌▌▌" FontSize="14" Foreground="#5A6B82"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" x:Name="txtScanInput"
                                 Style="{StaticResource ScanTextBoxStyle}"
                                 Height="40"/>
                        --><!-- Placeholder text overlay --><!--
                        <TextBlock Grid.Column="1" Text="Quét mã vạch hoặc nhập mã sản phẩm…"
                                   Foreground="#8696AD" FontSize="14" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtScanInput}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Border Grid.Column="2" Background="#EEF2F7" BorderBrush="#D8DEE7"
                                BorderThickness="1" CornerRadius="3" Padding="6,2">
                            <TextBlock Text="F2 — Tìm kiếm" FontSize="11" Foreground="#8696AD"
                                       FontFamily="Consolas"/>
                        </Border>
                    </Grid>
                </Border>

                --><!-- Customer button --><!--
                <Button Grid.Column="1" Style="{StaticResource ToolButtonStyle}"
                        Margin="0,0,8,0" x:Name="btnCustomer">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Khách hàng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                --><!-- Add Item button --><!--
                <Button Grid.Column="2" Style="{StaticResource ToolButtonStyle}"
                        x:Name="btnAddItem">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Thêm SP nhanh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        --><!-- ============================================================
             ROW 2  —  MAIN  (Cart LEFT | Actions Panel RIGHT)
             ============================================================ --><!--
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="460"/>
            </Grid.ColumnDefinitions>

            --><!-- =====================================================
                 LEFT — CART
                 ===================================================== --><!--
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    --><!-- Cart Header --><!--
                    <RowDefinition Height="*"/>
                    --><!-- Cart Body --><!--
                    <RowDefinition Height="Auto"/>
                    --><!-- Totals --><!--
                </Grid.RowDefinitions>

                --><!-- Cart Column Headers --><!--
                <Border Grid.Row="0" Background="{StaticResource CartHeadGradient}"
                        BorderBrush="#B8C1CF" BorderThickness="0,0,1,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="NO"
                                   FontSize="11" FontWeight="Bold" Foreground="#5A6B82"
                                   HorizontalAlignment="Right" Padding="8,10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Mã SP"   Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   />
                        <TextBlock Grid.Column="2" Text="Tên sản phẩm" Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   />
                        <TextBlock Grid.Column="3" Text="Giá" Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="4" Text="SL" Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="Số tiền" Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="6" Text="G. chú" Padding="8,10" FontSize="11" FontWeight="Bold"
                                   Foreground="#5A6B82"  VerticalAlignment="Center"
                                   />
                    </Grid>
                </Border>

                --><!-- Cart Body --><!--
                <Border Grid.Row="1" BorderBrush="#D8DEE7" BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="CartItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="rowBorder" BorderBrush="#D8DEE7"
                                            BorderThickness="0,0,0,1" Height="39"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E6F5ED"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#E6F5ED"/>
                                                        <Setter Property="BorderThickness" Value="4,0,0,1"/>
                                                        <Setter Property="BorderBrush" Value="#00824A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding RowNum}"
                                                       Foreground="#8696AD" FontFamily="Consolas" FontSize="12"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Code}"
                                                       Foreground="#2C3E5A" FontFamily="Consolas" FontSize="12"
                                                       VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                       FontWeight="Medium" FontSize="13"
                                                       VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="{Binding PriceFormatted}"
                                                       FontFamily="Consolas" FontWeight="SemiBold" FontSize="13"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Qty}"
                                                       FontFamily="Consolas" FontWeight="SemiBold" FontSize="13"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{Binding AmountFormatted}"
                                                       FontFamily="Consolas" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="#00824A"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="6" Text="{Binding Note}"
                                                       Foreground="#8696AD" FontSize="11" FontStyle="Italic"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                --><!-- TOTALS PANEL --><!--
                <Border Grid.Row="2" Background="{StaticResource TotalsGradient}"
                        BorderBrush="#B8C1CF" BorderThickness="0,2,1,0" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        --><!-- Subtotal --><!--
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tạm tính"
                                   FontSize="13" Foreground="#2C3E5A" FontWeight="Medium"
                                   VerticalAlignment="Center" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtSubtotal"
                                   Text="0 ₫" FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Margin="0,2"/>

                        --><!-- Discount --><!--
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Khuyến mãi / Giảm giá"
                                   FontSize="13" Foreground="#2C3E5A" FontWeight="Medium" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDiscount"
                                   Text="−0 ₫" FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#C0392B" HorizontalAlignment="Right" Margin="0,2"/>

                        --><!-- VAT --><!--
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="VAT (đã bao gồm)"
                                   FontSize="13" Foreground="#2C3E5A" FontWeight="Medium" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtVat"
                                   Text="0 ₫" FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#5A6B82" HorizontalAlignment="Right" Margin="0,2"/>

                        --><!-- Divider --><!--
                        <Border Grid.Row="3" Grid.ColumnSpan="2"
                                BorderBrush="#B8C1CF" BorderThickness="0,0,0,1" Margin="0,4"/>

                        --><!-- Grand Total --><!--
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="TỔNG CỘNG"
                                   FontSize="16" FontWeight="Bold" Foreground="#0B1C33"
                                   VerticalAlignment="Center" Margin="0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtGrandTotal"
                                   Text="0 ₫" FontFamily="Consolas" FontSize="28" FontWeight="ExtraBold"
                                   Foreground="#00824A" HorizontalAlignment="Right" Margin="0,4"/>

                        --><!-- Paid --><!--
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Tiền khách trả"
                                   FontSize="13" Foreground="#2C3E5A" FontWeight="Medium" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtPaid"
                                   Text="0 ₫" FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Margin="0,2"/>

                        --><!-- Change --><!--
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Tiền thối lại"
                                   FontSize="13" Foreground="#2C3E5A" FontWeight="Medium" Margin="0,2"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtChange"
                                   Text="0 ₫" FontFamily="Consolas" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#D97706" HorizontalAlignment="Right" Margin="0,2"/>
                    </Grid>
                </Border>
            </Grid>

            --><!-- =====================================================
                 RIGHT — ACTIONS PANEL
                 ===================================================== --><!--
            <Grid Grid.Column="1" Background="#F7F9FC">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    --><!-- Panel Tabs --><!--
                    <RowDefinition Height="*"/>
                    --><!-- Action Grid --><!--
                    <RowDefinition Height="Auto"/>
                    --><!-- Keypad --><!--
                </Grid.RowDefinitions>

                --><!-- Panel Tabs --><!--
                <Border Grid.Row="0" Background="#EEF2F7" BorderBrush="#D8DEE7" BorderThickness="0,0,0,1"
                        Padding="6,6,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource TabButtonStyle}" x:Name="btnTabFunc"
                                Content="Chức năng" Foreground="#0A3D62"
                                Background="White" BorderBrush="#D8DEE7" BorderThickness="1,1,1,0"/>
                        <Button Style="{StaticResource TabButtonStyle}" Content="Khuyến mãi" Margin="2,0,0,0"/>
                        <Button Style="{StaticResource TabButtonStyle}" Content="Phím tắt" Margin="2,0,0,0"/>
                    </StackPanel>
                </Border>

                --><!-- Action Grid (3 columns) --><!--
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        --><!-- Row 0 -->
                        <!-- Hoàn tiền (red) --><!--
                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="0,0,4,4">
                            <Border Background="#FDEBE9" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="↩" FontSize="22" Foreground="#C0392B" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Hoàn tiền" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#7F1D1D" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Khôi phục (blue) --><!--
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="2,0,2,4">
                            <Border Background="#E3F2FB" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Khôi phục" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#0C4A6E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Tích điểm (green) with badge --><!--
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="4,0,0,4">
                            <Grid>
                                <Border Background="#E8F7EF" CornerRadius="6">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Tích điểm&#10;Net Zero" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#064E30" HorizontalAlignment="Center"
                                                   TextAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#00824A" CornerRadius="3" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Padding="4,1" Margin="0,4,4,0">
                                    <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Button>

                        --><!-- Row 1 -->
                        <!-- Đổi tiền (amber) --><!--
                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="0,0,4,4">
                            <Border Background="#FEF3C7" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔁" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Đổi tiền" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#78350F" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Bán đặt trước (blue) --><!--
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="2,0,2,4">
                            <Border Background="#E3F2FB" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🛒" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Bán đặt trước" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#0C4A6E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Nhận đặt trước (blue) --><!--
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="4,0,0,4">
                            <Border Background="#E3F2FB" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nhận đặt trước" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#0C4A6E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Row 2 -->
                        <!-- Tìm chuyển đổi --><!--
                        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="0,0,4,4">
                            <Border Background="White" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔀" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tìm chuyển đổi" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#2C3E5A" HorizontalAlignment="Center"
                                               TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Tìm kiếm SP (amber) --><!--
                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="2,0,2,4">
                            <Border Background="#FEF3C7" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tìm kiếm SP" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#78350F" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Phát hành lại hoá đơn --><!--
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="4,0,0,4">
                            <Border Background="White" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🖨" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Phát hành lại&#10;hoá đơn" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#2C3E5A" HorizontalAlignment="Center"
                                               TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Row 3 -->
                        <!-- Giao hàng (blue) --><!--
                        <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="0,0,4,4">
                            <Border Background="#E3F2FB" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🚚" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Giao hàng" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#0C4A6E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Tạm giữ --><!--
                        <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="2,0,2,4">
                            <Border Background="White" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⏸" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Tạm giữ" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#2C3E5A" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Huỷ giao dịch (red) --><!--
                        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                Height="62" Margin="4,0,0,4" x:Name="btnCancelTransaction">
                            <Border Background="#FDEBE9" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🗑" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Huỷ giao dịch" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#7F1D1D" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        --><!-- Row 4 — KẾT THÚC BÁN (spans all 3 cols) --><!--
                        <Button Grid.Row="4" Grid.ColumnSpan="3"
                                x:Name="btnCheckout"
                                Height="64" Margin="0,0,0,4"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00A35D" Offset="0"/>
                                                <GradientStop Color="#00824A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✔" FontSize="22" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Text="KẾT THÚC BÁN — F12" FontSize="17" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </ScrollViewer>

                --><!-- KEYPAD --><!--
                <Border Grid.Row="2" Background="#D9EBF7" Padding="8">
                    <UniformGrid Columns="4" Rows="5">
                        --><!-- Row 1 --><!--
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="7" Height="42" Margin="3" x:Name="btnKey7"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="8" Height="42" Margin="3" x:Name="btnKey8"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="9" Height="42" Margin="3" x:Name="btnKey9"/>
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="⌫" Height="42" Margin="3" x:Name="btnKeyBack"/>
                        --><!-- Row 2 --><!--
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="4" Height="42" Margin="3" x:Name="btnKey4"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="5" Height="42" Margin="3" x:Name="btnKey5"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="6" Height="42" Margin="3" x:Name="btnKey6"/>
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="▲" Height="42" Margin="3" x:Name="btnKeyUp"/>
                        --><!-- Row 3 --><!--
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="1" Height="42" Margin="3" x:Name="btnKey1"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="2" Height="42" Margin="3" x:Name="btnKey2"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="3" Height="42" Margin="3" x:Name="btnKey3"/>
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="▼" Height="42" Margin="3" x:Name="btnKeyDown"/>
                        --><!-- Row 4 --><!--
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="0" Height="42" Margin="3" x:Name="btnKey0"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="00" Height="42" Margin="3" x:Name="btnKey00"/>
                        <Button Style="{StaticResource KeypadKeyStyle}" Content="." Height="42" Margin="3" x:Name="btnKeyDot"/>
                        <Button Style="{StaticResource KeypadEnterStyle}" Content="ENTER" Height="42" Margin="3" x:Name="btnKeyEnter"/>
                        --><!-- Row 5 --><!--
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="×SL" Height="42" Margin="3" x:Name="btnKeyQty"/>
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="DEL" Height="42" Margin="3" x:Name="btnKeyDel"/>
                        <Button Style="{StaticResource KeypadSpecialStyle}" Content="CLEAR" Height="42" Margin="3" x:Name="btnKeyClear"/>
                        <Button Style="{StaticResource KeypadCancelStyle}" Content="CANCEL" Height="42" Margin="3" x:Name="btnKeyCancel"/>
                    </UniformGrid>
                </Border>
            </Grid>
        </Grid>

        --><!-- ============================================================
             ROW 3  —  STATUS BAR
             ============================================================ --><!--
        <Border Grid.Row="3" Background="{StaticResource StatusBarGradient}"
                BorderBrush="#D8DEE7" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    --><!-- Online dot --><!--
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Ellipse Width="6" Height="6" Fill="#00824A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock FontSize="11" Foreground="#5A6B82" VerticalAlignment="Center">
                            <Run Text="Online" FontWeight="SemiBold" Foreground="#0B1C33"/>
                            <Run Text=" · Server đồng bộ"/>
                        </TextBlock>
                    </StackPanel>
                    --><!-- Store --><!--
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock Text="🖥 " FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock FontSize="11" Foreground="#5A6B82" VerticalAlignment="Center">
                            <Run Text="Cửa hàng "/>
                            <Run Text="Emart Sài Gòn" FontWeight="SemiBold" Foreground="#0B1C33"/>
                            <Run Text=" · Lane "/>
                            <Run Text="16" FontWeight="SemiBold" Foreground="#0B1C33"/>
                        </TextBlock>
                    </StackPanel>
                    --><!-- Printer --><!--
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <TextBlock FontSize="11" Foreground="#5A6B82" VerticalAlignment="Center">
                            <Run Text="Máy in: "/>
                            <Run Text="EPSON TM-T82III" FontWeight="SemiBold" Foreground="#0B1C33"/>
                        </TextBlock>
                    </StackPanel>
                    --><!-- Cash drawer --><!--
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="11" Foreground="#5A6B82" VerticalAlignment="Center">
                            <Run Text="Két tiền: "/>
                            <Run Text="Đóng" FontWeight="SemiBold" Foreground="#0B1C33"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                --><!-- Right side info --><!--
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#5A6B82" Margin="0,0,18,0">
                        <Run Text="Hoá đơn hôm nay: "/>
                        <Run Text="197" FontWeight="SemiBold" Foreground="#0B1C33"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#5A6B82" Margin="0,0,18,0">
                        <Run Text="Doanh thu ca: "/>
                        <Run Text="₫ 18.342.500" FontWeight="SemiBold" Foreground="#0B1C33"/>
                    </TextBlock>
                    <TextBlock Text="MartPOS v2.1.2.2 · Build 2026.04"
                               FontSize="10" FontFamily="Consolas" Foreground="#8696AD"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>-->

<Window x:Class="POS_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POS APP"
        Height="768"
        Width="1366"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>

        <LinearGradientBrush x:Key="PrimaryGradient"
                             StartPoint="0,0"
                             EndPoint="0,1">

            <GradientStop Color="#0A3D62" Offset="0"/>
            <GradientStop Color="#134D75" Offset="1"/>

        </LinearGradientBrush>

    </Window.Resources>

    <Grid>

        <ContentControl x:Name="MainContent" Background="Black"/>

    </Grid>

</Window>